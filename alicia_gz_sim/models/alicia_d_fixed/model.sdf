<?xml version="1.0"?>
<!--
  Alicia-D v5.6 Gazebo SDF Model
  转换自: Alicia_D_v5_6_gripper_100mm.urdf
  包含: base_link → Link1~Link6 → left_gripper/right_gripper → gripper_center
  关节: Joint1~Joint6 (revolute), Gripper (prismatic), right_finger (prismatic, mimic)

  ⚠️ 插件加载策略说明（2026-04-27 重构）
  本 model.sdf 在当前 launch 流程下**不被 bin_scene.sdf 静态 include**，
  机器人由 sim_demo.launch.py 通过 `ros_gz_sim create -topic /robot_description`
  从 URDF 动态 spawn。控制器与 JointState 插件由
  `alicia_moveit_config/config/alicia_d.ros2_control.xacro` 中的 <gazebo> 块声明，
  随 URDF 一起注入 Gazebo。所以本文件**不再声明** gz_ros2_control / JointStatePublisher
  插件，避免双重加载与配置冲突。

  本文件主要承担：
    1. 资源解析单元 — 提供 mesh 路径锚点 (model://alicia_d_fixed/...)
    2. 备用静态描述 — 若未来需要切回 SDF include 模式，可在此文件
       重新加入 <plugin> 块；同时需删除 ros2_control xacro 的 <gazebo> 块。

  mesh 路径使用 model://alicia_d_descriptions/... 协议，依赖
  GZ_SIM_RESOURCE_PATH 包含 alicia_d_descriptions/share（由 setup_env.sh 设置）。
-->
<sdf version="1.8">
  <model name="alicia_d_fixed">

    <!-- ============================================================ -->
    <!-- base_link                                                    -->
    <!-- 当前架构: 由 URDF (Alicia_D_v5_6_gripper_100mm.urdf.xacro)   -->
    <!--          内的 world→base_link fixed joint 锚定到世界          -->
    <!-- ============================================================ -->
    <link name="base_link">
      <inertial>
        <pose>0.00082623 0.00797844 0.04576751 0 0 0</pose>
        <mass>0.73396142</mass>
        <inertia>
          <ixx>0.001384103</ixx><ixy>0.000056720</ixy><ixz>0.000000514</ixz>
          <iyy>0.001736172</iyy><iyz>-0.000014865</iyz>
          <izz>0.002746677</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://alicia_d_descriptions/meshes/Alicia_D_v5_6/gripper_100mm/base_link.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.808 0.843 0.906 1</ambient>
          <diffuse>0.808 0.843 0.906 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://alicia_d_descriptions/meshes/Alicia_D_v5_6/gripper_100mm/base_link.STL</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!-- Link1                                                        -->
    <!-- ============================================================ -->
    <link name="Link1">
      <inertial>
        <pose>-0.00010985 -0.00001290 0.00303813 0 0 0</pose>
        <mass>0.19523345</mass>
        <inertia>
          <ixx>0.000258425</ixx><ixy>0.000000836</ixy><ixz>0.000002551</ixz>
          <iyy>0.000149308</iyy><iyz>-0.000001111</iyz>
          <izz>0.000339717</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://alicia_d_descriptions/meshes/Alicia_D_v5_6/gripper_100mm/Link1.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.796 0.824 0.937 1</ambient>
          <diffuse>0.796 0.824 0.937 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://alicia_d_descriptions/meshes/Alicia_D_v5_6/gripper_100mm/Link1.STL</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name="Joint1" type="revolute">
      <pose relative_to="base_link">0 0 0.1295 0 -0.03978184 0</pose>
      <parent>base_link</parent>
      <child>Link1</child>
      <axis>
        <xyz>-0.03977135 0 0.99920881</xyz>
        <limit>
          <lower>-2.749</lower>
          <upper>2.749</upper>
          <effort>5</effort>
          <velocity>12</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- ============================================================ -->
    <!-- Link2                                                        -->
    <!-- ============================================================ -->
    <link name="Link2">
      <inertial>
        <pose>0.15058870 0.00100783 0.00056760 0 0 0</pose>
        <mass>0.20703369</mass>
        <inertia>
          <ixx>0.000128136</ixx><ixy>0.000000119</ixy><ixz>0.000001667</ixz>
          <iyy>0.000205708</iyy><iyz>-0.000000350</iyz>
          <izz>0.000122721</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://alicia_d_descriptions/meshes/Alicia_D_v5_6/gripper_100mm/Link2.STL</uri>
