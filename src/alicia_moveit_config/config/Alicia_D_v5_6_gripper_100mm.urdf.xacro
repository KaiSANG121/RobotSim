<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Alicia_D_v5_6_gripper_100mm">
    <!-- Only parameter needed for Gazebo simulation -->
    <xacro:arg name="initial_positions_file"
               default="$(find alicia_moveit_config)/config/initial_positions.yaml" />

    <!-- Import Alicia-D URDF (robot kinematics + mesh) -->
    <xacro:include filename="$(find alicia_d_descriptions)/urdf/Alicia_D_v5_6/Alicia_D_v5_6_gripper_100mm.urdf" />

    <!-- Import gz_ros2_control xacro (replaces fake_components/GenericSystem) -->
    <xacro:include filename="$(find alicia_moveit_config)/config/alicia_d.ros2_control.xacro" />

    <!-- Anchor robot to the world (resolves Gazebo physics drifting FR-1.1) -->
    <link name="world"/>
    <joint name="world_fixed" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0.20 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Instantiate gz_ros2_control hardware interface -->
    <xacro:alicia_d_ros2_control
        name="AliciaGazeboHardware"
        initial_positions_file="$(arg initial_positions_file)"/>

</robot>
